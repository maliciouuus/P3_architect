{
  "info": {
    "name": "Renote API",
    "description": "Collection Postman — API REST Renote.\n\nFlux d'utilisation :\n1. Lancez 'Login' → le token est sauvegardé automatiquement dans {{token}}\n2. Toutes les autres requêtes utilisent ce token via l'onglet Auth Bearer\n\nAucun cookie, aucun CSRF.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register — créer un compte",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('✅ Token sauvegardé : ' + json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/register",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mon Nom\",\n  \"email\": \"mon@email.fr\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login — se connecter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('✅ Token sauvegardé : ' + json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/login",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mon@email.fr\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login — mauvais mot de passe (401 attendu)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/login",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mon@email.fr\",\n  \"password\": \"mauvais\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout — déconnexion",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/logout",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
    {
      "name": "🏷️ Tags",
      "item": [
        {
          "name": "GET /api/tags — liste tous les tags",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/tags",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "POST /api/tags — créer un tag",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/tags",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Travail\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "POST /api/tags — nom dupliqué (422 attendu)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/tags",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Travail\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "📝 Notes",
      "item": [
        {
          "name": "GET /api/notes — liste les notes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "GET /api/notes — sans token (401 attendu)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "POST /api/notes — créer une note",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Ma note de test\",\n  \"tag_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "POST /api/notes — champs manquants (422 attendu)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Note sans tag\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "DELETE /api/notes/:id — supprimer une note",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/notes/1",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "DELETE /api/notes/99999 — inexistante (404 attendu)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/notes/99999",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    }
  ]
}
