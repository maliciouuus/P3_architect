{
  "info": {
    "name": "Renote API",
    "description": "Collection Postman pour tester l'API REST de Renote.\n\nPré-requis : être connecté sur http://localhost:8000 dans votre navigateur (créer un compte puis se connecter).\nEnsuite dans Postman : Settings > Cookies > ajouter localhost comme domaine autorisé.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Tags",
      "item": [
        {
          "name": "GET /api/tags — Liste tous les tags",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/tags",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "POST /api/tags — Créer un tag",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/tags",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mon nouveau tag\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "GET /api/notes — Liste les notes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "POST /api/notes — Créer une note",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/notes",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Ma note de test\",\n  \"tag_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "DELETE /api/notes/:id — Supprimer une note",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/notes/1",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "1"]
            },
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" }
            ]
          }
        },
        {
          "name": "DELETE /api/notes/999 — Note inexistante (404)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/notes/999",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" }
            ]
          }
        }
      ]
    }
  ]
}
